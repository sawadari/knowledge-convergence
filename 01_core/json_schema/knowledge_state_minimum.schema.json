{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-convergence.local/schema/knowledge_state_minimum.schema.json",
  "title": "KnowledgeStateMinimum",
  "type": "object",
  "required": [
    "state_id",
    "G",
    "C",
    "E"
  ],
  "properties": {
    "state_id": {
      "type": "string"
    },
    "G": {
      "type": "object",
      "required": [
        "claims"
      ],
      "properties": {
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "claim_id"
            ],
            "properties": {
              "claim_id": {
                "type": "string"
              },
              "statement": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "relation_id"
            ],
            "properties": {
              "relation_id": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "constraint_id"
            ],
            "properties": {
              "constraint_id": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "relations"
          ]
        },
        {
          "required": [
            "constraints"
          ]
        }
      ],
      "additionalProperties": true
    },
    "C": {
      "type": "object",
      "required": [
        "scope"
      ],
      "properties": {
        "scope": {
          "type": [
            "string",
            "object",
            "array"
          ]
        },
        "horizon": {
          "type": [
            "string",
            "object",
            "array"
          ]
        },
        "intent": {
          "type": [
            "string",
            "object",
            "array"
          ]
        }
      },
      "anyOf": [
        {
          "required": [
            "horizon"
          ]
        },
        {
          "required": [
            "intent"
          ]
        }
      ],
      "additionalProperties": true
    },
    "E": {
      "type": "object",
      "required": [
        "bindings"
      ],
      "properties": {
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "claim_id"
            ],
            "properties": {
              "claim_id": {
                "type": "string"
              },
              "evidence_ref": {
                "type": "string"
              },
              "evidence_status": {
                "type": "string",
                "enum": [
                  "linked",
                  "absent",
                  "pending",
                  "external_ref",
                  "not_applicable",
                  "disputed"
                ]
              }
            },
            "anyOf": [
              {
                "required": [
                  "evidence_ref"
                ]
              },
              {
                "required": [
                  "evidence_status"
                ]
              }
            ],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "V": {
      "type": "object",
      "additionalProperties": true
    },
    "R": {
      "type": "object",
      "additionalProperties": true
    },
    "H": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}